# Server domain (without https://, without www)
# e.g. mydomain.com
# Required in production only.
CADDY_HOST=mydomain.com

# Base URL of the palladium-stack API
# - Dev:  http://localhost:8080  (stack running locally, flask-cors enabled)
# - Prod: leave empty           (Caddy proxies /api/* → palladium-dashboard:API_PORT, see below)
API_BASE_URL=

# Port palladium-stack's Flask app listens on inside its container
# (Prod only — Caddy reverse-proxies /api/* to palladium-dashboard:<this port>
# over the shared Docker network. Default: 8080)
API_PORT=8080

# API key to authenticate calls to /api/* of palladium-stack
# Must match the API_KEY in palladium-stack/.env
# Generate with: bash ~/palladium-stack/generate-api-key.sh
# In production: Caddy reads this and injects the X-API-Key header server-side (never exposed to the browser)
API_KEY=change-me-to-a-long-random-api-key

# Path to the ckpool log directory from palladium-stack
# - Dev:  set to the ckpool logs path to enable pool data sync; leave empty to disable
# - Prod: required — mounted read-only into the container (no sync script runs in prod)
# Example: /home/user/palladium-stack/logs
POOL_LOG_DIR=
