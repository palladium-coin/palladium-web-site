# Server domain (without https://, without www)
# e.g. mydomain.com
CADDY_HOST=miodominio.com

# Base URL of the palladium-stack API
# - Dev:  http://localhost:8080  (stack running locally, flask-cors enabled)
# - Prod: leave empty           (Caddy proxies /api/* → localhost:8080)
API_BASE_URL=

# API key to authenticate calls to /api/* of palladium-stack
# Must match the API_KEY in palladium-stack/.env
# Generate with: bash ~/palladium-stack/generate-api-key.sh
API_KEY=change-me-to-a-long-random-api-key
