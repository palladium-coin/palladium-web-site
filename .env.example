# URL base dell'API palladium-stack
# - Dev:  http://localhost:8080  (stack in esecuzione locale, flask-cors abilitato)
# - Prod: lascia vuoto           (Caddy proxia /api/* → localhost:8080)
API_BASE_URL=http://localhost:8080

# API key per autenticare le chiamate verso /api/* del palladium-stack
# Deve corrispondere all'API_KEY in palladium-stack/.env
# Genera con: bash ~/palladium-stack/generate-api-key.sh
API_KEY=change-me-to-a-long-random-api-key
